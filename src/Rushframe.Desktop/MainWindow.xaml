<Window x:Class="Rushframe.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:Rushframe.Desktop.Commands"
        xmlns:ui="clr-namespace:Rushframe.Desktop.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Rushframe"
        Icon="Assets/Rushframe_icon.png"
        Width="1220"
        Height="650"
        MinWidth="1024"
        MinHeight="560"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="50"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="10"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.CommandBindings>
        <CommandBinding Command="c:EditorCommands.TogglePanel" Executed="TogglePanel_Executed" />
    </Window.CommandBindings>

    <Window.Resources>
        <ContextMenu x:Key="TimelineClipContextMenu">
            <MenuItem Header="Split at Playhead" Command="c:EditorCommands.SplitClip" InputGestureText="Ctrl+B" />
            <Separator />
            <MenuItem Header="Cut" Command="c:EditorCommands.Cut" InputGestureText="Ctrl+X" />
            <MenuItem Header="Copy" Command="c:EditorCommands.Copy" InputGestureText="Ctrl+C" />
            <MenuItem Header="Paste" Command="c:EditorCommands.Paste" InputGestureText="Ctrl+V" />
            <MenuItem Header="Duplicate" Command="c:EditorCommands.Duplicate" InputGestureText="Ctrl+D" />
            <Separator />
            <MenuItem Header="Ripple Delete" Command="c:EditorCommands.RippleDelete" />
            <MenuItem Header="Delete" Command="c:EditorCommands.DeleteClip" InputGestureText="Delete" />
        </ContextMenu>

        <ContextMenu x:Key="TrackHeaderContextMenu">
            <MenuItem Header="Rename Track" x:Name="RenameTrackMenuItem" />
            <MenuItem Header="Duplicate Track" x:Name="DuplicateTrackMenuItem" />
            <Separator />
            <MenuItem Header="Mute Track" x:Name="MuteTrackMenuItem" IsCheckable="True" />
            <MenuItem Header="Solo Track" x:Name="SoloTrackMenuItem" IsCheckable="True" />
            <MenuItem Header="Lock Track" x:Name="LockTrackMenuItem" IsCheckable="True" />
            <Separator />
            <MenuItem Header="Delete Track" x:Name="DeleteTrackMenuItem" />
        </ContextMenu>

        <Style x:Key="RailButtonStyle" TargetType="Button" BasedOn="{StaticResource CommandButtonStyle}">
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActiveRailButtonStyle" TargetType="Button" BasedOn="{StaticResource RailButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
        </Style>

        <Style x:Key="RailIconStyle" TargetType="Path">
            <Setter Property="Width" Value="17" />
            <Setter Property="Height" Value="17" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="StrokeThickness" Value="1.55" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Fill" Value="Transparent" />
        </Style>

        <Style x:Key="CompactTabButtonStyle" TargetType="Button" BasedOn="{StaticResource CommandButtonStyle}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="10.5" />
        </Style>

        <Style x:Key="InspectorSectionStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="14,13" />
        </Style>

        <Style x:Key="InspectorFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="InspectorHeadingStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,11" />
        </Style>

        <Style x:Key="InspectorEffectComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactMonitorComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource EditorRailBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource InspectorEffectComboItemStyle}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,0,28,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboChrome"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="5">
                                            <Grid>
                                                <TextBlock Margin="9,0,27,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           Text="{Binding SelectedItem.Content, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="{StaticResource TextMutedBrush}"
                                                      StrokeThickness="1.4"
                                                      Width="8" Height="4"
                                                      Stretch="Fill"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboChrome" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="240"
                                        Background="{StaticResource PanelRaisedBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="3">
                                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InspectorEffectComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource EditorRailBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,0,34,0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource InspectorEffectComboItemStyle}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboChrome"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="5">
                                            <Grid>
                                                <ContentPresenter Margin="10,0,34,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Border Width="30" HorizontalAlignment="Right" Background="Transparent">
                                                    <Path Data="M 0 0 L 4 4 L 8 0"
                                                          Stroke="{StaticResource TextMutedBrush}"
                                                          StrokeThickness="1.4"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Width="8" Height="4"
                                                          Stretch="Fill"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboChrome" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="260"
                                        Background="{StaticResource PanelRaisedBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="4">
                                    <ScrollViewer CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InspectorExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ToggleButton x:Name="HeaderToggle"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Content="{TemplateBinding Header}"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              Padding="14,10"
                                              Cursor="Hand"
                                              FocusVisualStyle="{x:Null}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="HeaderChrome"
                                                    Background="{StaticResource EditorRailBrush}"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Left"
                                                                      RecognizesAccessKey="True"
                                                                      TextElement.FontSize="11.5"
                                                                      TextElement.FontWeight="SemiBold"
                                                                      TextElement.Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <Path x:Name="HeaderArrow"
                                                          Grid.Column="1"
                                                          Data="M3,5 L7,9 L11,5"
                                                          Stroke="{StaticResource TextMutedBrush}"
                                                          StrokeThickness="1.6"
                                                          Width="12"
                                                          Height="8"
                                                          Stretch="Uniform"
                                                          VerticalAlignment="Center"
                                                          RenderTransformOrigin="0.5,0.5" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HeaderChrome" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                                    <Setter TargetName="HeaderArrow" Property="Stroke" Value="{StaticResource AccentHoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="HeaderChrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                                    <Setter TargetName="HeaderChrome" Property="BorderBrush" Value="{StaticResource SelectionBrush}" />
                                                    <Setter TargetName="HeaderChrome" Property="BorderThickness" Value="1" />
                                                    <Setter TargetName="HeaderArrow" Property="Stroke" Value="{StaticResource AccentHoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter TargetName="HeaderChrome" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                    <Setter TargetName="HeaderChrome" Property="BorderThickness" Value="1" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite"
                                                  Grid.Row="1"
                                                  Margin="14,10,14,13"
                                                  Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource TitleBarHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource TitleBarPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="0,0,0,2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource CloseHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ClosePressedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="0,0,0,2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowFrameBorder"
            Background="{StaticResource WindowBrush}"
            BorderBrush="{StaticResource BorderStrongBrush}"
            BorderThickness="1"
            CornerRadius="10"
            ClipToBounds="True"
            SnapsToDevicePixels="True">
    <Grid Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <!-- Application header -->
        <Border Grid.Row="0"
                Background="{StaticResource EditorHeaderBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Border x:Name="HeaderBrandIcon" Width="24" Height="24" CornerRadius="5" Background="{StaticResource PanelRaisedBrush}" Margin="0,0,10,0" ClipToBounds="True">
                        <Image Source="Assets/Rushframe_icon.png"
                               Width="24"
                               Height="24"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <TextBlock x:Name="HeaderBrandText" Text="" Visibility="Collapsed" />
                    <Menu>
                        <MenuItem Header="File">
                            <MenuItem Header="Open Project" Command="c:EditorCommands.OpenProject" InputGestureText="Ctrl+O" />
                            <MenuItem Header="Save Project" Command="c:EditorCommands.SaveProject" InputGestureText="Ctrl+S" />
                            <Separator />
                            <MenuItem Header="Import Media" Command="c:EditorCommands.ImportMedia" InputGestureText="Ctrl+I" />
                            <MenuItem Header="Relink Selected Media" Command="c:EditorCommands.RelinkMedia" />
                            <MenuItem Header="Generate Media Cache" Command="c:EditorCommands.GenerateMediaCache" />
                            <MenuItem Header="Import Media Intelligence" Command="c:EditorCommands.ImportMediaIntelligence" />
                            <Separator />
                            <MenuItem Header="Export" Command="c:EditorCommands.Render" InputGestureText="Ctrl+R" />
                        </MenuItem>
                        <MenuItem Header="View">
                            <MenuItem Header="Panels" x:Name="PanelsMenu" />
                        </MenuItem>
                    </Menu>
                    <Button x:Name="McpStatusButton"
                            Style="{StaticResource CommandButtonStyle}"
                            Content="MCP"
                            MinWidth="48"
                            Height="30"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            ToolTip="Open local agent setup and status" />
                </StackPanel>

                <TextBlock x:Name="HeaderCenterTitle"
                           Grid.Column="1"
                           Text="Rushframe Editor"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           IsHitTestVisible="False" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.Undo" ToolTip="Undo (Ctrl+Z)" AutomationProperties.Name="Undo">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M7,5 L3,9 L7,13 M3,9 L11,9 C14,9 16,11 16,14" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.Redo" ToolTip="Redo (Ctrl+Y)" AutomationProperties.Name="Redo" Margin="0,0,4,0">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M11,5 L15,9 L11,13 M15,9 L7,9 C4,9 2,11 2,14" />
                    </Button>
                    <Button x:Name="SettingsButton" Style="{StaticResource IconButtonStyle}" ToolTip="Settings (Ctrl+,)" AutomationProperties.Name="Settings" Margin="0,0,8,0">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M9,3 A6,6 0 1 0 9,15 A6,6 0 1 0 9,3 M9,6 A3,3 0 1 0 9,12 A3,3 0 1 0 9,6" />
                    </Button>
                    <Button x:Name="HeaderExportButton"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="c:EditorCommands.Render"
                            MinWidth="104"
                            Margin="0,7,10,7"
                            ToolTip="Export project (Ctrl+R)"
                            AutomationProperties.Name="Export project">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource ToolbarIconStyle}" Stroke="White" Data="M3,12 L3,15 L15,15 L15,12 M9,2 L9,11 M5.5,7.5 L9,11 L12.5,7.5" />
                            <TextBlock Text="Export" Foreground="White" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="MinimizeWindowButton"
                            Style="{StaticResource WindowControlButtonStyle}"
                            ToolTip="Minimize"
                            AutomationProperties.Name="Minimize window">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,10 L14,10" />
                    </Button>
                    <Button x:Name="MaximizeWindowButton"
                            Style="{StaticResource WindowControlButtonStyle}"
                            ToolTip="Maximize"
                            AutomationProperties.Name="Maximize or restore window">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,4 L14,4 L14,14 L4,14 Z" />
                    </Button>
                    <Button x:Name="CloseWindowButton"
                            Style="{StaticResource CloseWindowControlButtonStyle}"
                            ToolTip="Close"
                            AutomationProperties.Name="Close window">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,5 L13,13 M13,5 L5,13" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Editor workspace -->
        <Grid x:Name="MainGrid" Grid.Row="1" Background="{StaticResource WindowBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MediaColumn" Width="390" MinWidth="0" />
                <ColumnDefinition x:Name="MediaSplitterColumn" Width="4" />
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition x:Name="InspectorSplitterColumn" Width="4" />
                <ColumnDefinition x:Name="InspectorColumn" Width="300" MinWidth="0" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="WorkspaceRow" Height="*" MinHeight="0" />
                <RowDefinition Height="46" />
                <RowDefinition x:Name="TimelineRow" Height="250" MinHeight="180" />
            </Grid.RowDefinitions>

            <!-- Library rail and asset browser -->
            <Border x:Name="MediaBorder"
                    Grid.Column="0"
                    Grid.Row="0"
                    Background="{StaticResource EditorPanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58" />
                        <ColumnDefinition x:Name="AssetPanelColumn" Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource EditorRailBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,1,0">
                        <StackPanel Margin="0,10,0,10">
                            <Button x:Name="SideMediaButton" Style="{StaticResource ActiveRailButtonStyle}" ToolTip="Show or hide project assets" AutomationProperties.Name="Upload media">
                                <StackPanel>
                                    <Path Style="{StaticResource RailIconStyle}" Data="M9,2 L9,12 M5,6 L9,2 L13,6 M3,12 L3,16 L15,16 L15,12" HorizontalAlignment="Center" />
                                    <TextBlock Text="Upload" FontSize="10.5" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Grid x:Name="AssetPanelContent" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="42" />
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="32" />
                        </Grid.RowDefinitions>

                        <Grid Margin="14,0,12,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Project Assets" FontWeight="SemiBold" FontSize="13" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="14,7,12,7">
                            <Grid>
                                <TextBox x:Name="MediaSearchBox" Padding="28,5,8,5" ToolTip="Filter media by file name" AutomationProperties.Name="Search project assets" />
                                <Path Data="M7,2 A5,5 0 1 0 7,12 A5,5 0 1 0 7,2 M11,11 L16,16"
                                      Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.4" Width="16" Height="16" Stretch="Uniform" Margin="8,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" />
                                <TextBlock x:Name="MediaSearchHint"
                                           Text="Search assets..."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="29,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="2" Margin="14,0,12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="AllMediaFilterButton" Grid.Column="0" Style="{StaticResource CompactTabButtonStyle}" Content="All" />
                            <Button x:Name="VideoFilterButton" Grid.Column="1" Style="{StaticResource CompactTabButtonStyle}" Content="Video" />
                            <Button x:Name="AudioFilterButton" Grid.Column="2" Style="{StaticResource CompactTabButtonStyle}" Content="Audio" />
                            <Button x:Name="ImageFilterButton" Grid.Column="3" Style="{StaticResource CompactTabButtonStyle}" Content="Images" />
                        </Grid>

                        <Grid Grid.Row="3" Margin="10,4,8,0">
                            <ListBox x:Name="MediaList"
                                     SelectionMode="Single"
                                     ScrollViewer.CanContentScroll="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ui:VirtualizingWrapPanel ItemWidth="108" ItemHeight="102" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                        <Setter Property="Height" Value="102" />
                                        <Setter Property="Padding" Value="3" />
                                        <Setter Property="Margin" Value="2" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="66" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border CornerRadius="5"
                                                    Background="{StaticResource EditorMonitorBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <TextBlock Text="{Binding FallbackGlyph}"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               FontSize="20"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="{StaticResource AccentSurfaceBrush}" CornerRadius="0,0,4,0" Padding="4,2">
                                                        <TextBlock Text="{Binding KindText}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentHoverBrush}" />
                                                    </Border>
                                                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="{StaticResource EditorOverlayBrush}" CornerRadius="4,0,0,0" Padding="4,2">
                                                        <TextBlock Text="{Binding DurationText}" FontFamily="Cascadia Mono, Consolas" FontSize="10" Foreground="White" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Row="1" Margin="1,4,1,0">
                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="10.5" TextTrimming="CharacterEllipsis" ToolTip="{Binding Asset.OriginalPath}" />
                                                <TextBlock Text="{Binding DurationText}" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" Margin="0,1,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel x:Name="MediaEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="42" Height="42" CornerRadius="9" Background="{StaticResource AccentSurfaceBrush}" HorizontalAlignment="Center">
                                    <Path Data="M4,6 L9,6 L11,8 L18,8 L17,17 L4,17 Z" Stroke="{StaticResource AccentHoverBrush}" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Margin="10" />
                                </Border>
                                <TextBlock Text="No project assets" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0" />
                                <TextBlock Text="Import media to begin editing." Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,4,0,0" />
                                <Button Style="{StaticResource PrimaryButtonStyle}" Command="c:EditorCommands.ImportMedia" Content="Import Media" Margin="0,12,0,0" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,0">
                            <Grid>
                                <TextBlock x:Name="MediaCountText" Text="0 items" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button x:Name="PreviewSelectedMediaButton" Style="{StaticResource CommandButtonStyle}" Content="Preview" ToolTip="Preview selected asset" />
                                    <Button x:Name="AddToTimelineButton" Style="{StaticResource PrimaryButtonStyle}" Content="Add" MinWidth="52" Margin="5,0,0,0" ToolTip="Add selected asset to timeline" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter x:Name="MediaSplitter"
                          Grid.Column="1"
                          Grid.Row="0"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Source monitor -->
            <Border x:Name="PreviewBorder"
                    Grid.Column="2"
                    Grid.Row="0"
                    Background="{StaticResource ChromeBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="76" />
                    </Grid.RowDefinitions>

                    <Grid Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Source Monitor" FontWeight="SemiBold" FontSize="12" />
                            <TextBlock x:Name="ProjectNameText" Text="Untitled Project" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="10,0,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="PreviewSourceNameText" Grid.Column="1" Text="Nothing selected" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="260" />
                    </Grid>

                    <Border Grid.Row="1" Background="{StaticResource EditorMonitorBrush}" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" CornerRadius="4" Margin="14,0,14,5" ClipToBounds="True">
                        <Grid x:Name="PreviewSurface">
                            <Grid.LayoutTransform>
                                <ScaleTransform x:Name="PreviewScaleTransform" ScaleX="1" ScaleY="1" />
                            </Grid.LayoutTransform>
                            <Image x:Name="PreviewImage" Visibility="Collapsed" Stretch="Uniform" />
                            <MediaElement x:Name="PreviewPlayer"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Manual"
                                          Stretch="Uniform"
                                          ScrubbingEnabled="True"
                                          Volume="1" />
                            <Grid x:Name="PreviewGuidesOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                                <Border Margin="40" BorderBrush="#66FFFFFF" BorderThickness="1" />
                                <Border Margin="20" BorderBrush="#33FFFFFF" BorderThickness="1" />
                                <Border Width="1" Background="#44FFFFFF" HorizontalAlignment="Center" />
                                <Border Height="1" Background="#44FFFFFF" VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="66" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PreviewTimeText" Text="00:00" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource AccentHoverBrush}" FontSize="10.5" VerticalAlignment="Center" />
                        <Slider x:Name="PreviewSeekSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="1"
                                Value="0"
                                SmallChange="0.1"
                                LargeChange="1"
                                IsMoveToPointEnabled="True"
                                Margin="8,0"
                                ToolTip="Click or drag to seek"
                                AutomationProperties.Name="Source preview position" />
                        <TextBlock x:Name="PreviewDurationText" Grid.Column="2" Text="00:00" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="3" Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PreviewTimeBox" Width="82" Height="24" Text="00:00" FontFamily="Cascadia Mono, Consolas" FontSize="10.5" VerticalContentAlignment="Center" ToolTip="Enter source timecode" />
                        <TextBlock x:Name="PreviewMarkInText" Grid.Column="1" Text="In --:--" Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0" />
                        <TextBlock x:Name="PreviewMarkOutText" Grid.Column="2" Text="Out --:--" Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0" />
                        <ComboBox x:Name="PreviewRecentCombo" Grid.Column="4" Width="150" Height="24" DisplayMemberPath="OriginalPath" ToolTip="Recent source media" />
                    </Grid>

                    <Border Grid.Row="4" Background="{StaticResource EditorRailBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Grid Margin="10,6">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          PanningMode="HorizontalOnly">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="PreviewMarkInButton" Style="{StaticResource IconButtonStyle}" Content="I" ToolTip="Mark In (I)" AutomationProperties.Name="Set source mark in" />
                                    <Button x:Name="PreviewMarkOutButton" Style="{StaticResource IconButtonStyle}" Content="O" ToolTip="Mark Out (O)" AutomationProperties.Name="Set source mark out" />
                                    <Button x:Name="PreviewClearMarksButton" Style="{StaticResource IconButtonStyle}" Content="×" ToolTip="Clear In/Out" AutomationProperties.Name="Clear source marks" />
                                    <Button x:Name="PreviewPreviousFrameButton" Style="{StaticResource IconButtonStyle}" Content="◀|" ToolTip="Previous frame (Left)" AutomationProperties.Name="Previous source frame" />
                                    <Button x:Name="PreviewStopButton" Style="{StaticResource IconButtonStyle}" ToolTip="Stop" AutomationProperties.Name="Stop source preview">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,5 L13,5 L13,13 L5,13 Z" Fill="{StaticResource TextSecondaryBrush}" StrokeThickness="0" />
                                    </Button>
                                    <Button x:Name="PreviewPauseButton" Style="{StaticResource TransportButtonStyle}" ToolTip="Pause" AutomationProperties.Name="Pause source preview">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,4 L8,4 L8,14 L5,14 Z M10,4 L13,4 L13,14 L10,14 Z" Fill="{StaticResource TextSecondaryBrush}" StrokeThickness="0" />
                                    </Button>
                                    <Button x:Name="PreviewPlayButton" Style="{StaticResource PrimaryButtonStyle}" MinWidth="44" Margin="4,0" ToolTip="Play/Pause (Space)" AutomationProperties.Name="Play source preview">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,3 L15,9 L5,15 Z" Fill="White" StrokeThickness="0" />
                                    </Button>
                                    <Button x:Name="PreviewNextFrameButton" Style="{StaticResource IconButtonStyle}" Content="|▶" ToolTip="Next frame (Right)" AutomationProperties.Name="Next source frame" />
                                    <ToggleButton x:Name="PreviewLoopToggle" Style="{StaticResource ToolToggleButtonStyle}" Content="Loop" ToolTip="Loop marked range" />
                                    <ComboBox x:Name="PreviewSpeedCombo" Style="{StaticResource CompactMonitorComboStyle}" Width="72" Margin="4,0" ToolTip="Playback speed">
                                        <ComboBoxItem Content="0.25x" Tag="0.25" />
                                        <ComboBoxItem Content="0.5x" Tag="0.5" />
                                        <ComboBoxItem Content="1x" Tag="1" IsSelected="True" />
                                        <ComboBoxItem Content="1.5x" Tag="1.5" />
                                        <ComboBoxItem Content="2x" Tag="2" />
                                    </ComboBox>
                                    <Button x:Name="PreviewInsertButton" Style="{StaticResource CommandButtonStyle}" Content="Insert" Margin="4,0,0,0" ToolTip="Insert marked range at playhead" />
                                    <Button x:Name="PreviewOverwriteButton" Style="{StaticResource CommandButtonStyle}" Content="Overwrite" Margin="4,0,0,0" ToolTip="Overwrite marked range at playhead" />
                                    <ToggleButton x:Name="PreviewMuteToggle" Style="{StaticResource ToolToggleButtonStyle}" Content="Mute" Margin="12,0,0,0" />
                                    <Slider x:Name="PreviewVolumeSlider" Width="62" Minimum="0" Maximum="1" Value="1" Margin="4,0" ToolTip="Preview volume" />
                                    <ComboBox x:Name="PreviewZoomCombo" Style="{StaticResource CompactMonitorComboStyle}" Width="78" ToolTip="Monitor zoom">
                                        <ComboBoxItem Content="Fit" Tag="1" IsSelected="True" />
                                        <ComboBoxItem Content="50%" Tag="0.5" />
                                        <ComboBoxItem Content="100%" Tag="1" />
                                        <ComboBoxItem Content="200%" Tag="2" />
                                    </ComboBox>
                                    <ToggleButton x:Name="PreviewGuidesToggle" Style="{StaticResource ToolToggleButtonStyle}" Content="Guides" Margin="4,0,0,0" />
                                    <Button x:Name="PreviewSnapshotButton" Style="{StaticResource IconButtonStyle}" Content="▣" ToolTip="Save current frame" AutomationProperties.Name="Save preview snapshot" />
                                    <Button x:Name="PreviewFullscreenButton" Style="{StaticResource IconButtonStyle}" Content="⛶" ToolTip="Toggle fullscreen monitor" AutomationProperties.Name="Toggle preview fullscreen" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right inspector dock -->
            <GridSplitter x:Name="InspectorSplitter"
                          Grid.Column="3"
                          Grid.Row="0"
                          Grid.RowSpan="3"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Grid Grid.Column="4" Grid.Row="0" Grid.RowSpan="3">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="RightInspectorRow" Height="*" />
                    <RowDefinition x:Name="RightTasksRow" Height="0" />
                </Grid.RowDefinitions>

                <Border x:Name="InspectorBorder"
                        Grid.Row="0"
                        Background="{StaticResource EditorPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="52" />
                        </Grid.RowDefinitions>
                    <TabControl x:Name="InspectorTabs" Grid.Row="0" Background="Transparent">
                        <TabItem Header="Inspector">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Margin="14,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="11" Height="11" BorderBrush="{StaticResource TextMutedBrush}" BorderThickness="1" CornerRadius="2" Margin="0,0,7,0" />
                                        <TextBlock x:Name="InspectorTitle" Text="No clip selected" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="250" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid x:Name="InspectorPanel">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel>
                                                <Border x:Name="TransitionInspectorCard" Style="{StaticResource InspectorSectionStyle}" Visibility="Collapsed">
                                                    <StackPanel>
                                                        <TextBlock Text="Transition" Style="{StaticResource InspectorHeadingStyle}" />
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                            <TextBlock Text="Type" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <ComboBox x:Name="TransitionKindCombo" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,7" />
                                                            <TextBlock Text="Duration" Grid.Row="1" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <TextBox x:Name="TransitionDurationBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,6,7" />
                                                            <TextBlock Text="s" Grid.Row="1" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,0,7" />
                                                            <TextBlock Text="Alignment" Grid.Row="2" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <TextBox x:Name="TransitionAlignmentBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="2" Grid.Column="1" Margin="0,0,6,0" />
                                                            <TextBlock Text="%" Grid.Row="2" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <Expander Header="Transform" Style="{StaticResource InspectorExpanderStyle}" IsExpanded="True">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                        <TextBlock Text="Position X" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                        <TextBox x:Name="PositionXBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Column="1" Margin="0,0,6,7" ToolTip="Horizontal position" />
                                                        <TextBlock Text="px" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,0,7" />
                                                        <TextBlock Text="Position Y" Grid.Row="1" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                        <TextBox x:Name="PositionYBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,6,7" ToolTip="Vertical position" />
                                                        <TextBlock Text="px" Grid.Row="1" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,0,7" />
                                                        <TextBlock Text="Scale" Grid.Row="2" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                        <TextBox x:Name="ScaleBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="2" Grid.Column="1" Margin="0,0,6,7" />
                                                        <TextBlock Text="x" Grid.Row="2" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,0,7" />
                                                        <TextBlock Text="Rotation" Grid.Row="3" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                        <TextBox x:Name="RotationBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="3" Grid.Column="1" Margin="0,0,6,7" />
                                                        <TextBlock Text="°" Grid.Row="3" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,0,7" />
                                                        <TextBlock Text="Opacity" Grid.Row="4" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                        <TextBox x:Name="OpacityBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="4" Grid.Column="1" Margin="0,0,6,0" />
                                                        <TextBlock Text="%" Grid.Row="4" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Expander>

                                                <Expander Header="Timing" Style="{StaticResource InspectorExpanderStyle}" IsExpanded="True">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Speed" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <TextBox x:Name="SpeedBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Column="1" Margin="0,0,6,0" />
                                                            <TextBlock Text="x" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                        </Grid>
                                                        <CheckBox x:Name="ReverseToggle" Content="Reverse playback" Margin="78,9,0,0" />
                                                    </StackPanel>
                                                </Expander>

                                                <Expander Header="Color" Style="{StaticResource InspectorExpanderStyle}" IsExpanded="True">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /><ColumnDefinition Width="58" /></Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                            <TextBlock Text="Brightness" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <Slider x:Name="BrightnessSlider" Grid.Column="1" Minimum="-1" Maximum="1" Value="0" Margin="0,0,7,7" AutomationProperties.Name="Brightness" />
                                                            <TextBox x:Name="BrightnessBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Column="2" Margin="0,0,0,7" />
                                                            <TextBlock Text="Contrast" Grid.Row="1" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <Slider x:Name="ContrastSlider" Grid.Row="1" Grid.Column="1" Minimum="-1" Maximum="3" Value="0" Margin="0,0,7,7" AutomationProperties.Name="Contrast" />
                                                            <TextBox x:Name="ContrastBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="1" Grid.Column="2" Margin="0,0,0,7" />
                                                            <TextBlock Text="Saturation" Grid.Row="2" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <Slider x:Name="SaturationSlider" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="4" Value="1" Margin="0,0,7,0" AutomationProperties.Name="Saturation" />
                                                            <TextBox x:Name="SaturationBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="2" Grid.Column="2" />
                                                        </Grid>
                                                        <CheckBox x:Name="BlackWhiteToggle" Content="Black and white" Margin="78,9,0,0" />
                                                    </StackPanel>
                                                </Expander>

                                                <Expander Header="Stabilization" Style="{StaticResource InspectorExpanderStyle}" IsExpanded="False">
                                                    <StackPanel>
                                                        <CheckBox x:Name="StabilizeToggle" Content="Enable stabilization" />
                                                        <Button x:Name="AnalyzeStabilizationButton" Content="Analyze Motion" Margin="0,9,0,0" HorizontalAlignment="Stretch" />
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>

                                    <StackPanel x:Name="InspectorEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="28" IsHitTestVisible="False">
                                        <Border Width="44" Height="44" CornerRadius="10" Background="{StaticResource AccentSurfaceBrush}" HorizontalAlignment="Center">
                                            <Path Data="M4,4 L16,4 L16,16 L4,16 Z M7,8 L13,8 M7,11 L12,11" Stroke="{StaticResource AccentHoverBrush}" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Margin="10" />
                                        </Border>
                                        <TextBlock Text="Select a timeline clip" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,11,0,0" />
                                        <TextBlock Text="Transform, timing, color and audio properties will appear here." Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="230" Margin="0,5,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Effects">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Clip Effects" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="Add and manage effects on the selected timeline clip." Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,14" />
                                    <ComboBox x:Name="EffectCombo"
                                              Style="{StaticResource InspectorEffectComboStyle}"
                                              DisplayMemberPath="Name" />
                                    <Button x:Name="AddEffectButton" Content="Add Selected Effect" Margin="0,8,0,0" />
                                    <TextBlock Text="Applied Effects" Style="{StaticResource InspectorHeadingStyle}" Margin="0,18,0,8" />
                                    <ListBox x:Name="EffectList"
                                             MinHeight="130"
                                             Background="{StaticResource InputBrush}"
                                             DisplayMemberPath="DisplayName" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="EffectMoveUpButton" Content="Move Up" Margin="0,0,4,0" />
                                        <Button x:Name="EffectMoveDownButton" Grid.Column="1" Content="Move Down" Margin="4,0" />
                                        <Button x:Name="EffectRemoveButton" Grid.Column="2" Content="Remove" Margin="4,0,0,0" />
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="EffectToggleButton" Content="Disable" Margin="0,0,4,0" />
                                        <Button x:Name="EffectDuplicateButton" Grid.Column="1" Content="Duplicate" Margin="4,0" />
                                        <Button x:Name="EffectResetButton" Grid.Column="2" Content="Reset" Margin="4,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="Parameters" Style="{StaticResource InspectorHeadingStyle}" Margin="0,18,0,8" />
                                    <Border Background="{StaticResource InputBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="10">
                                        <StackPanel x:Name="EffectParameterPanel">
                                            <TextBlock Text="Select an applied effect to edit its parameters."
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10.5"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Button x:Name="EffectApplyParametersButton"
                                            Content="Apply Effect Parameters"
                                            Margin="0,8,0,0" />
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Audio">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Style="{StaticResource InspectorSectionStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Audio" Style="{StaticResource InspectorHeadingStyle}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="72" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                <TextBlock Text="Volume" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                <TextBox x:Name="VolumeBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Column="1" Margin="0,0,6,8" />
                                                <TextBlock Text="%" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,0,8" />
                                                <TextBlock Text="Pan" Grid.Row="1" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                <TextBox x:Name="PanBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,6,0" />
                                                <TextBlock Text="%" Grid.Row="1" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                            </Grid>
                                            <TextBlock Text="Pan uses -100 for left, 0 for center, and 100 for right." Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" Margin="72,7,0,0" />
                                            <Button Command="c:EditorCommands.ExtractAudio" Content="Extract Audio" Margin="0,12,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                        <Border Grid.Row="1" Background="{StaticResource EditorRailBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="10,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="InspectorDirtyText" Text="Select a clip to edit" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="ResetInspectorButton" Style="{StaticResource CommandButtonStyle}" Content="Reset" Margin="0,0,6,0" IsEnabled="False" />
                                    <Button x:Name="ApplyInspectorButton" Style="{StaticResource PrimaryButtonStyle}" Content="Apply" MinWidth="72" IsEnabled="False" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="TasksBorder"
                        Grid.Row="1"
                        Background="{StaticResource EditorPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1,1,0,0"
                        Visibility="Collapsed">
                    <TabControl>
                        <TabItem x:Name="TasksTab" Header="Campaign">
                            <Grid Margin="9">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Campaign brief" FontWeight="SemiBold" FontSize="11.5" Margin="0,0,0,5" />
                                    <TextBox x:Name="CampaignDescriptionBox"
                                             MinHeight="48"
                                             MaxHeight="72"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             ToolTip="Describe the campaign goal and editing direction"
                                             AutomationProperties.Name="Campaign description" />
                                </StackPanel>
                                <Grid Grid.Row="1" Margin="0,8,0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NewTaskBox"
                                             ToolTip="Enter a task"
                                             AutomationProperties.Name="New campaign task" />
                                    <Button x:Name="AddTaskButton"
                                            Grid.Column="1"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Content="Add"
                                            MinWidth="58"
                                            Margin="6,0,0,0" />
                                </Grid>
                                <Grid Grid.Row="2">
                                    <ListBox x:Name="TaskList" Margin="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                                              VerticalAlignment="Center"
                                                              AutomationProperties.Name="Mark task complete" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Margin="2,0,8,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <Button Grid.Column="2"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            Tag="{Binding Id}"
                                                            Click="DeleteCampaignTask_Click"
                                                            ToolTip="Delete task"
                                                            AutomationProperties.Name="Delete task">
                                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,5 L14,5 M7,5 L7,3 L11,3 L11,5 M6,7 L6,15 L12,15 L12,7" />
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock x:Name="TasksEmptyText"
                                               Text="No campaign tasks yet"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False" />
                                </Grid>
                            </Grid>
                        </TabItem>
                        <TabItem x:Name="RenderQueueTab" Header="Activity">
                            <Grid>
                                <ListBox x:Name="RenderQueueList" Margin="5" AutomationProperties.Name="Background activity log" />
                                <TextBlock x:Name="RenderQueueEmptyText" Text="No background activity yet" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
                            </Grid>
                        </TabItem>
                        <TabItem x:Name="MediaIntelligenceTab" Header="Intelligence">
                            <DockPanel Margin="7">
                                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,7">
                                    <CheckBox x:Name="AnalyzeScenesToggle" Content="Scenes" IsChecked="True" Margin="0,0,9,5" />
                                    <CheckBox x:Name="AnalyzeTranscriptToggle" Content="Transcript" IsChecked="True" Margin="0,0,9,5" />
                                    <CheckBox x:Name="AnalyzeMusicToggle" Content="Audio + beats" IsChecked="True" Margin="0,0,9,5" />
                                    <CheckBox x:Name="AnalyzeGeminiToggle" Content="Visual understanding" Margin="0,0,6,5" />
                                    <ComboBox x:Name="VisualProviderCombo" Width="112" SelectedIndex="0" Margin="0,0,9,5" ToolTip="Choose the visual-analysis provider" AutomationProperties.Name="Visual analysis provider">
                                        <ComboBoxItem Content="Gemini" Tag="gemini" />
                                        <ComboBoxItem Content="Qwen local" Tag="qwen" />
                                    </ComboBox>
                                    <CheckBox x:Name="AnalyzeOcrToggle" Content="OCR" Margin="0,0,9,5" />
                                    <CheckBox x:Name="AnalyzeAlignmentToggle" Content="Precise words" Margin="0,0,9,5" />
                                    <CheckBox x:Name="AnalyzeDiarizationToggle" Content="Speakers" Margin="0,0,9,5" />
                                    <CheckBox x:Name="AnalyzeAudioEventsToggle" Content="Sound events" Margin="0,0,9,5" />
                                    <CheckBox x:Name="BuildEmbeddingsToggle" Content="Semantic index" Margin="0,0,9,5" />
                                    <ComboBox x:Name="WhisperModelCombo" Width="92" SelectedIndex="0" Margin="0,0,6,5" ToolTip="Choose the speech transcription model" AutomationProperties.Name="Speech transcription model">
                                        <ComboBoxItem Content="base" /><ComboBoxItem Content="small" /><ComboBoxItem Content="medium" />
                                    </ComboBox>
                                    <Button x:Name="RunMediaIntelligenceButton" Content="Analyze selected media" MinWidth="126" Margin="0,0,5,5" />
                                    <Button x:Name="ApplyMediaIntelligenceButton" Content="Apply results" MinWidth="88" Margin="0,0,5,5" />
                                    <Button x:Name="OpenMediaAnalysisButton" Content="Open results" MinWidth="88" Margin="0,0,9,5" />
                                    <TextBox x:Name="MediaContextSearchBox" Width="200" MinHeight="29" Margin="0,0,5,5" ToolTip="Search analyzed scenes, speech, sound, and editing roles" AutomationProperties.Name="Search analyzed media context" />
                                    <Button x:Name="SearchMediaContextButton" Content="Search analysis" MinWidth="96" Margin="0,0,5,5" />
                                    <Button x:Name="FindHooksButton" Content="Find best hooks" MinWidth="98" Margin="0,0,0,5" />
                                </WrapPanel>
                                <Grid>
                                    <ListBox x:Name="MediaIntelligenceList" />
                                    <TextBlock x:Name="MediaIntelligenceEmptyText" Text="Select media, then run analysis" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
                                </Grid>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>

            <!-- Timeline toolbar -->
            <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Background="{StaticResource EditorRailBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,1,1">
                <Grid Margin="9,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource CommandButtonStyle}" Command="c:EditorCommands.SplitClip" ToolTip="Split the selected clip at the playhead" AutomationProperties.Name="Split clip">
                            <StackPanel Orientation="Horizontal"><Path Style="{StaticResource ToolbarIconStyle}" Data="M4,4 L14,14 M14,4 L4,14" /><TextBlock Text="Split" /></StackPanel>
                        </Button>
                        <ToggleButton x:Name="RippleToggle" Style="{StaticResource ToolToggleButtonStyle}" Content="Ripple" IsChecked="False" ToolTip="Close gaps after supported edits" Margin="6,0,4,0" AutomationProperties.Name="Ripple editing" />
                        <ToggleButton x:Name="SnapToggle" Style="{StaticResource ToolToggleButtonStyle}" Content="Snap" IsChecked="True" ToolTip="Snap clips and markers" Margin="0,0,8,0" AutomationProperties.Name="Timeline snapping" />
                        <Button Style="{StaticResource CommandButtonStyle}" Command="c:EditorCommands.AddText" ToolTip="Add a text clip" AutomationProperties.Name="Add text">
                            <StackPanel Orientation="Horizontal"><Path Style="{StaticResource ToolbarIconStyle}" Data="M3,3 L15,3 M9,3 L9,15 M6,15 L12,15" /><TextBlock Text="Text" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.Duplicate" ToolTip="Duplicate selected clip" AutomationProperties.Name="Duplicate selected clip">
                            <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,5 L15,5 L15,15 L5,15 Z M2,2 L12,2 L12,5 M2,2 L2,12 L5,12" />
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.DeleteClip" ToolTip="Delete selected clip" AutomationProperties.Name="Delete selected clip">
                            <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,5 L14,5 M7,5 L7,3 L11,3 L11,5 M6,7 L6,15 L12,15 L12,7" />
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.AddMarker" ToolTip="Add marker at the playhead" AutomationProperties.Name="Add timeline marker">
                            <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,2 L14,2 L14,10 L9.5,10 L6,14 L6,10 L5,10 Z" />
                        </Button>
                    </StackPanel>
                    </ScrollViewer>
                    <StackPanel x:Name="TimelineZoomControls" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Background="{StaticResource EditorRailBrush}" Margin="8,0,0,0">
                        <Path Data="M2,9 A7,7 0 1 0 16,9 A7,7 0 1 0 2,9 M7,9 L11,9" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.3" Width="15" Height="15" Stretch="Uniform" Margin="0,0,8,0" />
                        <Slider x:Name="ZoomSlider" Width="118" Minimum="0.1" Maximum="10" Value="1" TickFrequency="0.1" AutomationProperties.Name="Timeline zoom" />
                        <Path Data="M2,9 A7,7 0 1 0 16,9 A7,7 0 1 0 2,9 M6,9 L12,9 M9,6 L9,12" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.3" Width="15" Height="15" Stretch="Uniform" Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter x:Name="PreviewTimelineSplitter"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Grid.Row="1"
                          Height="4"
                          VerticalAlignment="Top"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Timeline canvas -->
            <Border x:Name="TimelineBorder"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Grid.Row="2"
                    Background="{StaticResource ChromeBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ContentControl x:Name="TimelineHost" />
            </Border>

            <GridSplitter x:Name="TimelineTasksSplitter" Visibility="Collapsed" />
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource EditorHeaderBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" FontSize="10.5" TextTrimming="CharacterEllipsis" />
                <ProgressBar x:Name="OperationProgressBar" Grid.Column="1" Width="96" Height="5" Margin="10,0" IsIndeterminate="True" Visibility="Collapsed" AutomationProperties.Name="Current operation progress" />
                <Button x:Name="CancelOperationButton" Grid.Column="2" Content="Cancel" MinHeight="22" Padding="8,1" Margin="0,0,10,0" Visibility="Collapsed" AutomationProperties.Name="Cancel current operation" />
                <TextBlock x:Name="LocalEditingStatusText" Grid.Column="3" Text="Rushframe — Local editing" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="10.5" />
                <TextBlock x:Name="AutosaveStatusText" Grid.Column="4" Text="Autosave enabled" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10.5" />
            </Grid>
        </Border>
    </Grid>
    </Border>
</Window>
