<Window x:Class="Rushframe.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:Rushframe.Desktop.Commands"
        xmlns:ui="clr-namespace:Rushframe.Desktop.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Rushframe"
        Icon="Assets/Rushframe_icon.png"
        Width="1220"
        Height="650"
        MinWidth="1120"
        MinHeight="620"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="50"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="10"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.CommandBindings>
        <CommandBinding Command="c:EditorCommands.TogglePanel" Executed="TogglePanel_Executed" />
    </Window.CommandBindings>

    <Window.Resources>
        <ContextMenu x:Key="TimelineClipContextMenu">
            <MenuItem Header="Split at Playhead" Command="c:EditorCommands.SplitClip" InputGestureText="Ctrl+B" />
            <Separator />
            <MenuItem Header="Cut" Command="c:EditorCommands.Cut" InputGestureText="Ctrl+X" />
            <MenuItem Header="Copy" Command="c:EditorCommands.Copy" InputGestureText="Ctrl+C" />
            <MenuItem Header="Paste" Command="c:EditorCommands.Paste" InputGestureText="Ctrl+V" />
            <MenuItem Header="Duplicate" Command="c:EditorCommands.Duplicate" InputGestureText="Ctrl+D" />
            <Separator />
            <MenuItem Header="Ripple Delete" Command="c:EditorCommands.RippleDelete" />
            <MenuItem Header="Delete" Command="c:EditorCommands.DeleteClip" InputGestureText="Delete" />
        </ContextMenu>

        <ContextMenu x:Key="TrackHeaderContextMenu">
            <MenuItem Header="Rename Track" x:Name="RenameTrackMenuItem" />
            <MenuItem Header="Duplicate Track" x:Name="DuplicateTrackMenuItem" />
            <Separator />
            <MenuItem Header="Mute Track" x:Name="MuteTrackMenuItem" IsCheckable="True" />
            <MenuItem Header="Solo Track" x:Name="SoloTrackMenuItem" IsCheckable="True" />
            <MenuItem Header="Lock Track" x:Name="LockTrackMenuItem" IsCheckable="True" />
            <Separator />
            <MenuItem Header="Delete Track" x:Name="DeleteTrackMenuItem" />
        </ContextMenu>

        <Style x:Key="RailButtonStyle" TargetType="Button" BasedOn="{StaticResource CommandButtonStyle}">
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActiveRailButtonStyle" TargetType="Button" BasedOn="{StaticResource RailButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
        </Style>

        <Style x:Key="RailIconStyle" TargetType="Path">
            <Setter Property="Width" Value="17" />
            <Setter Property="Height" Value="17" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="StrokeThickness" Value="1.55" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Fill" Value="Transparent" />
        </Style>

        <Style x:Key="OperationProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <Grid Margin="1" ClipToBounds="True">
                                <Border x:Name="PART_Track"
                                        Background="{StaticResource PanelRaisedBrush}"
                                        CornerRadius="3" />
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="3" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="PART_Indicator" Property="Width" Value="44" />
                                <Setter TargetName="PART_Indicator" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactTabButtonStyle" TargetType="Button" BasedOn="{StaticResource CommandButtonStyle}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="10.5" />
        </Style>

        <Style x:Key="HeaderNoHoverButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="350" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SubtleHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PressedSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderNoHoverIconButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderNoHoverButtonStyle}">
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="InspectorSectionStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="14,13" />
        </Style>

        <Style x:Key="InspectorFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="InspectorHeadingStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,11" />
        </Style>

        <Style x:Key="InspectorEffectComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InspectorEffectComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource EditorRailBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,0,34,0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource InspectorEffectComboItemStyle}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboChrome"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="5">
                                            <Grid>
                                                <ContentPresenter Margin="10,0,34,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Border Width="30" HorizontalAlignment="Right" Background="Transparent">
                                                    <Path Data="M 0 0 L 4 4 L 8 0"
                                                          Stroke="{StaticResource TextMutedBrush}"
                                                          StrokeThickness="1.4"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Width="8" Height="4"
                                                          Stretch="Fill"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboChrome" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="260"
                                        Background="{StaticResource PanelRaisedBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="4">
                                    <ScrollViewer CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InspectorExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ToggleButton x:Name="HeaderToggle"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Content="{TemplateBinding Header}"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              Padding="14,10"
                                              Cursor="Hand"
                                              FocusVisualStyle="{x:Null}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="HeaderChrome"
                                                    Background="{StaticResource EditorRailBrush}"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Left"
                                                                      RecognizesAccessKey="True"
                                                                      TextElement.FontSize="11.5"
                                                                      TextElement.FontWeight="SemiBold"
                                                                      TextElement.Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <Path x:Name="HeaderArrow"
                                                          Grid.Column="1"
                                                          Data="M3,5 L7,9 L11,5"
                                                          Stroke="{StaticResource TextMutedBrush}"
                                                          StrokeThickness="1.6"
                                                          Width="12"
                                                          Height="8"
                                                          Stretch="Uniform"
                                                          VerticalAlignment="Center"
                                                          RenderTransformOrigin="0.5,0.5" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HeaderChrome" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                                    <Setter TargetName="HeaderArrow" Property="Stroke" Value="{StaticResource AccentHoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="HeaderChrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                                    <Setter TargetName="HeaderChrome" Property="BorderBrush" Value="{StaticResource SelectionBrush}" />
                                                    <Setter TargetName="HeaderChrome" Property="BorderThickness" Value="1" />
                                                    <Setter TargetName="HeaderArrow" Property="Stroke" Value="{StaticResource AccentHoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter TargetName="HeaderChrome" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                    <Setter TargetName="HeaderChrome" Property="BorderThickness" Value="1" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite"
                                                  Grid.Row="1"
                                                  Margin="14,10,14,13"
                                                  Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource TitleBarHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource TitleBarPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource CloseHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ClosePressedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowFrameBorder"
            Background="{StaticResource WindowBrush}"
            BorderBrush="{StaticResource BorderStrongBrush}"
            BorderThickness="1"
            CornerRadius="10"
            ClipToBounds="True"
            SnapsToDevicePixels="True">
    <Grid Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <!-- Application header -->
        <Border Grid.Row="0"
                Background="{StaticResource EditorHeaderBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ScrollViewer x:Name="HeaderMenuScrollViewer"
                              Grid.Column="0"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              PanningMode="HorizontalOnly"
                              Focusable="False"
                              PreviewMouseWheel="HeaderMenuScrollViewer_PreviewMouseWheel"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border x:Name="HeaderBrandIcon" Width="24" Height="24" CornerRadius="5" Background="{StaticResource PanelRaisedBrush}" Margin="0,0,10,0" ClipToBounds="True">
                        <Image Source="Assets/Rushframe_icon.png"
                               Width="24"
                               Height="24"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <TextBlock x:Name="HeaderBrandText" Text="" Visibility="Collapsed" />
                    <Menu>
                        <MenuItem Header="File">
                            <MenuItem Header="New Project" Command="c:EditorCommands.NewProject" InputGestureText="Ctrl+N" />
                            <MenuItem Header="Open Project" Command="c:EditorCommands.OpenProject" InputGestureText="Ctrl+O" />
                            <MenuItem x:Name="OpenRecentMenu" Header="Open Recent" />
                            <MenuItem x:Name="RecoverLatestAutosaveMenuItem" Header="Recover Latest Autosave" />
                            <MenuItem Header="Save Project" Command="c:EditorCommands.SaveProject" InputGestureText="Ctrl+S" />
                            <Separator />
                            <MenuItem Header="Import Media" Command="c:EditorCommands.ImportMedia" InputGestureText="Ctrl+I" />
                            <MenuItem Header="Relink Selected Media" Command="c:EditorCommands.RelinkMedia" />
                            <MenuItem Header="Generate Media Cache" Command="c:EditorCommands.GenerateMediaCache" />
                            <MenuItem Header="Import AI Analysis" Command="c:EditorCommands.ImportMediaIntelligence" />
                            <Separator />
                            <MenuItem Header="Export" Command="c:EditorCommands.Render" InputGestureText="Ctrl+R" />
                        </MenuItem>
                        <MenuItem Header="Preferences">
                            <MenuItem Header="View" x:Name="PanelsMenu" />
                        </MenuItem>
                    </Menu>
                    <Button x:Name="McpStatusButton"
                            Style="{StaticResource HeaderNoHoverIconButtonStyle}"
                            Width="42"
                            Height="30"
                            Margin="8,0,0,0"
                            ToolTip="Open local agent setup and MCP status"
                            AutomationProperties.Name="Local agent and MCP status">
                        <TextBlock Text="MCP"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Border Margin="8,0,0,0"
                            Padding="0"
                            MinWidth="96"
                            MaxWidth="220"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="0"
                            ToolTip="Click to rename the project; press Enter to save"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Grid>
                            <TextBlock x:Name="ProjectNameText"
                                       Text="Untitled"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Cursor="IBeam"
                                       AutomationProperties.Name="Project name" />
                            <TextBox x:Name="ProjectNameEditBox"
                                     Visibility="Collapsed"
                                     MinHeight="24"
                                     Padding="2,0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     AutomationProperties.Name="Edit project name" />
                        </Grid>
                    </Border>
                </StackPanel>
                </ScrollViewer>

                <Button x:Name="GlobalFunctionSearchButton"
                        Grid.Column="1"
                        Width="34"
                        Height="30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{StaticResource HeaderNoHoverIconButtonStyle}"
                        ToolTip="Search commands (Ctrl+K)"
                        AutomationProperties.Name="Search commands"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Style="{StaticResource ToolbarIconStyle}"
                          Margin="0"
                          Data="M3,8 A5,5 0 1 0 13,8 A5,5 0 1 0 3,8 M11.5,11.5 L16,16" />
                </Button>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource HeaderNoHoverIconButtonStyle}" Command="c:EditorCommands.Undo" ToolTip="Undo (Ctrl+Z)" AutomationProperties.Name="Undo">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M7,5 L3,9 L7,13 M3,9 L11,9 C14,9 16,11 16,14" />
                    </Button>
                    <Button Style="{StaticResource HeaderNoHoverIconButtonStyle}" Command="c:EditorCommands.Redo" ToolTip="Redo (Ctrl+Y)" AutomationProperties.Name="Redo" Margin="0,0,4,0">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M11,5 L15,9 L11,13 M15,9 L7,9 C4,9 2,11 2,14" />
                    </Button>
                    <Button x:Name="SettingsButton" Style="{StaticResource HeaderNoHoverIconButtonStyle}" ToolTip="Settings (Ctrl+,)" AutomationProperties.Name="Settings" Margin="0,0,8,0">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M9,2 L10,4.2 L12.4,3.6 L13.4,5.8 L15.8,6.4 L15.2,8.8 L17,10.5 L15.2,12.2 L15.8,14.6 L13.4,15.2 L12.4,17.4 L10,16.8 L9,19 L8,16.8 L5.6,17.4 L4.6,15.2 L2.2,14.6 L2.8,12.2 L1,10.5 L2.8,8.8 L2.2,6.4 L4.6,5.8 L5.6,3.6 L8,4.2 Z M6.5,10.5 A2.5,2.5 0 1 0 11.5,10.5 A2.5,2.5 0 1 0 6.5,10.5" />
                    </Button>
                    <Button x:Name="HeaderExportButton"
                            Style="{StaticResource PrimaryIconButtonStyle}"
                            Command="c:EditorCommands.Render"
                            Width="40"
                            Margin="0,7,10,7"
                            ToolTip="Export project (Ctrl+R)"
                            AutomationProperties.Name="Export project">
                        <Path Style="{StaticResource ToolbarIconStyle}" Stroke="White" Data="M3,12 L3,15 L15,15 L15,12 M9,2 L9,11 M5.5,7.5 L9,11 L12.5,7.5" />
                    </Button>
                    <Button x:Name="MinimizeWindowButton"
                            Style="{StaticResource WindowControlButtonStyle}"
                            ToolTip="Minimize"
                            AutomationProperties.Name="Minimize window">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,10 L14,10" />
                    </Button>
                    <Button x:Name="MaximizeWindowButton"
                            Style="{StaticResource WindowControlButtonStyle}"
                            ToolTip="Maximize"
                            AutomationProperties.Name="Maximize or restore window">
                        <Path x:Name="MaximizeWindowIcon" Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,4 L14,4 L14,14 L4,14 Z" />
                    </Button>
                    <Button x:Name="CloseWindowButton"
                            Style="{StaticResource CloseWindowControlButtonStyle}"
                            ToolTip="Close"
                            AutomationProperties.Name="Close window">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,5 L13,13 M13,5 L5,13" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Editor workspace -->
        <Grid x:Name="MainGrid" Grid.Row="1" Background="{StaticResource WindowBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MediaColumn" Width="*" MinWidth="160" />
                <ColumnDefinition x:Name="MediaSplitterColumn" Width="4" />
                <ColumnDefinition x:Name="PreviewColumn" Width="*" MinWidth="160" />
                <ColumnDefinition x:Name="InspectorSplitterColumn" Width="4" />
                <ColumnDefinition x:Name="InspectorColumn" Width="*" MinWidth="160" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="WorkspaceRow" Height="*" MinHeight="160" />
                <RowDefinition x:Name="WorkspaceSplitterRow" Height="4" />
                <RowDefinition x:Name="TimelineRow" Height="*" MinHeight="160" />
            </Grid.RowDefinitions>

            <!-- Library rail and asset browser -->
            <Border x:Name="MediaBorder"
                    Grid.Column="0"
                    Grid.Row="0"
                    AutomationProperties.Name="Media window"
                    Background="{StaticResource EditorPanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="AssetPanelColumn" Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="AssetPanelContent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="48" />
                            <RowDefinition Height="38" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="MediaWindowTitleBar"
                              Margin="8,0,12,0"
                              Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="MediaWindowDragHandle"
                                    Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    Cursor="SizeAll"
                                    Background="Transparent"
                                    ToolTip="Drag to move Project Files"
                                    AutomationProperties.Name="Move Project Files window">
                                <TextBlock Text="⠿" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                            </Border>
                            <TextBlock x:Name="MediaWindowTitleText"
                                       Grid.Column="1"
                                       Text="Project Files"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False" />
                            <Button x:Name="MediaCloseWindowButton"
                                    Grid.Column="2"
                                    Style="{StaticResource IconButtonStyle}"
                                    Width="28"
                                    Height="28"
                                    Visibility="Collapsed"
                                    ToolTip="Close Project Files window"
                                    AutomationProperties.Name="Close Project Files window">
                                <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,5 L13,13 M13,5 L5,13" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1" Margin="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="170" />
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <TextBox x:Name="MediaSearchBox"
                                         MinHeight="32"
                                         Padding="30,0,8,0"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Search project files by name or folder"
                                         AutomationProperties.Name="Search project files" />
                                <Path Data="M7,2 A5,5 0 1 0 7,12 A5,5 0 1 0 7,2 M11,11 L16,16"
                                      Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.4" Width="16" Height="16" Stretch="Uniform" Margin="8,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" />
                                <TextBlock x:Name="MediaSearchHint"
                                           Text="Search files or folders..."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="31,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                            </Grid>
                            <ComboBox x:Name="ProjectFolderFilterCombo"
                                      Grid.Column="2"
                                      SelectedIndex="0"
                                      ToolTip="Filter by source folder"
                                      AutomationProperties.Name="Project folder filter" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="AllMediaFilterButton" Grid.Column="0" Style="{StaticResource IconButtonStyle}" ToolTip="Show every project file" AutomationProperties.Name="All files">
                                <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,4 L8,4 L10,6 L16,6 L15,15 L3,15 Z" />
                            </Button>
                            <Button x:Name="VideoFilterButton" Grid.Column="1" Style="{StaticResource IconButtonStyle}" ToolTip="Show video files" AutomationProperties.Name="Video files">
                                <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,4 L13,4 L13,14 L3,14 Z M13,7 L17,5 L17,13 L13,11" />
                            </Button>
                            <Button x:Name="AudioFilterButton" Grid.Column="2" Style="{StaticResource IconButtonStyle}" ToolTip="Show audio files" AutomationProperties.Name="Audio files">
                                <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,7 L8,7 L12,4 L12,14 L8,11 L5,11 Z M14,7 C16,8 16,10 14,11" />
                            </Button>
                            <Button x:Name="ImageFilterButton" Grid.Column="3" Style="{StaticResource IconButtonStyle}" ToolTip="Show image files" AutomationProperties.Name="Image files">
                                <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,4 L15,4 L15,14 L3,14 Z M5,12 L9,8 L12,11 L14,9 M6,7 A1,1 0 1 0 8,7" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="3" Margin="8,5,8,0">
                            <ListView x:Name="MediaList"
                                      SelectionMode="Single"
                                      Background="Transparent"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      BorderThickness="1"
                                      Foreground="{StaticResource TextBrush}"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListView.Resources>
                                    <Style TargetType="{x:Type GridViewColumnHeader}">
                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                        <Setter Property="Background" Value="{StaticResource EditorRailBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                                        <Setter Property="Padding" Value="8,5" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                                                    <Border x:Name="HeaderChrome"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="HeaderChrome" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.Resources>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListViewItem}">
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="6,4" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ListViewItem}">
                                                    <Border x:Name="RowChrome"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="1"
                                                            Padding="{TemplateBinding Padding}">
                                                        <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="RowChrome" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="RowChrome" Property="Background" Value="{StaticResource SelectionBrush}" />
                                                            <Setter TargetName="RowChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView AllowsColumnReorder="True">
                                        <GridViewColumn Width="42">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Width="30" Height="24" CornerRadius="4" Background="{StaticResource EditorMonitorBrush}" ClipToBounds="True">
                                                        <Grid>
                                                            <TextBlock Text="{Binding FallbackGlyph}" FontSize="7.5" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" Width="190" DisplayMemberBinding="{Binding FileName}" />
                                        <GridViewColumn Header="Type" Width="78" DisplayMemberBinding="{Binding KindText}" />
                                        <GridViewColumn Header="Folder" Width="230" DisplayMemberBinding="{Binding FolderDisplayName}" />
                                        <GridViewColumn Header="Duration" Width="74" DisplayMemberBinding="{Binding DurationText}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <StackPanel x:Name="MediaEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="46" Height="46" CornerRadius="10" Background="{StaticResource AccentSurfaceBrush}" HorizontalAlignment="Center">
                                    <Path Data="M3,6 L8,6 L10,8 L17,8 L16,16 L3,16 Z" Stroke="{StaticResource AccentHoverBrush}" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Margin="11" />
                                </Border>
                                <TextBlock Text="No project files" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0" />
                                <TextBlock Text="Import video, audio, images, fonts, or subtitles." Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="240" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,0">
                            <Grid>
                                <TextBlock x:Name="MediaCountText" Text="0 files" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button x:Name="CreativeAssetsButton" Style="{StaticResource IconButtonStyle}" ToolTip="Browse licensed local creative assets" AutomationProperties.Name="Creative assets library">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,3 L8,3 L8,8 L3,8 Z M10,3 L15,3 L15,8 L10,8 Z M3,10 L8,10 L8,15 L3,15 Z M10,10 L15,10 L15,15 L10,15 Z" />
                                    </Button>
                                    <Button x:Name="PreviewSelectedMediaButton" Style="{StaticResource IconButtonStyle}" Margin="5,0,0,0" ToolTip="Preview selected file" AutomationProperties.Name="Preview selected file">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,3 L15,9 L5,15 Z" />
                                    </Button>
                                    <Button x:Name="AddToTimelineButton" Style="{StaticResource PrimaryIconButtonStyle}" Margin="5,0,0,0" ToolTip="Add selected file to timeline" AutomationProperties.Name="Add selected file to timeline">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Stroke="White" Margin="0" Data="M3,5 L15,5 M3,9 L11,9 M3,13 L11,13 M14,9 L14,15 M11,12 L17,12" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter x:Name="MediaSplitter"
                          Grid.Column="1"
                          Grid.Row="0"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Source monitor -->
            <Border x:Name="PreviewBorder"
                    Grid.Column="2"
                    Grid.Row="0"
                    AutomationProperties.Name="Preview window"
                    Background="{StaticResource ChromeBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="34" />
                        <RowDefinition x:Name="PreviewTransportRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="PreviewHeader"
                          Margin="6,0,10,0"
                          Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="PreviewWindowDragHandle"
                                Grid.Column="0"
                                Width="28"
                                Height="28"
                                Cursor="SizeAll"
                                Background="Transparent"
                                ToolTip="Drag to move Preview"
                                AutomationProperties.Name="Move Preview window">
                            <TextBlock Text="⠿" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <TextBlock x:Name="PreviewWindowTitleText"
                                   Grid.Column="1"
                                   Text="Preview"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="10,0,8,0">
                            <Button x:Name="PreviewPreviousFrameButton" Style="{StaticResource IconButtonStyle}" ToolTip="Previous frame (Left)" AutomationProperties.Name="Previous source frame">
                                <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,4 L4,14 M14,4 L7,9 L14,14 Z" />
                            </Button>
                            <Button x:Name="PreviewStopButton" Style="{StaticResource IconButtonStyle}" ToolTip="Stop" AutomationProperties.Name="Stop source preview">
                                <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,5 L13,5 L13,13 L5,13 Z" Fill="{StaticResource TextSecondaryBrush}" StrokeThickness="0" />
                            </Button>
                            <Button x:Name="PreviewPauseButton" Style="{StaticResource TransportButtonStyle}" ToolTip="Pause" AutomationProperties.Name="Pause source preview">
                                <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,4 L8,4 L8,14 L5,14 Z M10,4 L13,4 L13,14 L10,14 Z" Fill="{StaticResource TextSecondaryBrush}" StrokeThickness="0" />
                            </Button>
                            <Button x:Name="PreviewPlayButton" Style="{StaticResource PrimaryIconButtonStyle}" MinWidth="44" Margin="4,0" ToolTip="Play/Pause (Space)" AutomationProperties.Name="Play source preview">
                                <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,3 L15,9 L5,15 Z" Fill="White" StrokeThickness="0" />
                            </Button>
                            <Button x:Name="PreviewNextFrameButton" Style="{StaticResource IconButtonStyle}" ToolTip="Next frame (Right)" AutomationProperties.Name="Next source frame">
                                <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M14,4 L14,14 M4,4 L11,9 L4,14 Z" />
                            </Button>
                        </StackPanel>
                        <TextBlock x:Name="PreviewSourceNameText" Grid.Column="3" Text="Nothing selected" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="260" Margin="0,0,8,0" />
                        <Button x:Name="PreviewFreeLayoutButton"
                                Grid.Column="4"
                                Style="{StaticResource IconButtonStyle}"
                                Width="30" Height="28"
                                ToolTip="Use free adaptive Preview sizing"
                                AutomationProperties.Name="Free Preview layout">
                            <Path x:Name="PreviewFreeLayoutIcon" Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,7 L3,3 L7,3 M11,3 L15,3 L15,7 M15,11 L15,15 L11,15 M7,15 L3,15 L3,11 M6,6 L12,12 M12,6 L6,12" />
                        </Button>
                        <Button x:Name="PreviewFullscreenButton"
                                Grid.Column="5"
                                Style="{StaticResource IconButtonStyle}"
                                Width="30" Height="28"
                                ToolTip="Enter fullscreen Preview"
                                AutomationProperties.Name="Toggle fullscreen Preview">
                            <Path x:Name="PreviewFullscreenIcon" Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,7 L3,3 L7,3 M11,3 L15,3 L15,7 M15,11 L15,15 L11,15 M7,15 L3,15 L3,11" />
                        </Button>
                        <Button x:Name="PreviewOrientationButton"
                                Grid.Column="6"
                                Style="{StaticResource IconButtonStyle}"
                                Width="30" Height="28"
                                VerticalAlignment="Center"
                                ToolTip="Switch preview window to portrait"
                                AutomationProperties.Name="Switch preview window to portrait">
                            <Path x:Name="PreviewOrientationIcon" Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,2 L13,2 L13,16 L5,16 Z M8,14 L10,14" />
                        </Button>
                    </Grid>

                    <Border x:Name="PreviewMonitorBorder"
                            Grid.Row="1"
                            Margin="14,0,14,5"
                            Background="{StaticResource EditorMonitorBrush}"
                            BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            ClipToBounds="True">
                        <Grid x:Name="PreviewSurface">
                            <Grid.LayoutTransform>
                                <ScaleTransform x:Name="PreviewScaleTransform" ScaleX="1" ScaleY="1" />
                            </Grid.LayoutTransform>
                            <Image x:Name="PreviewImage" Visibility="Collapsed" Stretch="Uniform" />
                            <MediaElement x:Name="PreviewPlayer"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Manual"
                                          Stretch="Uniform"
                                          ScrubbingEnabled="True"
                                          Volume="1" />
                            <Viewbox x:Name="RealtimePreviewViewbox"
                                     Visibility="Collapsed"
                                     Stretch="Uniform"
                                     StretchDirection="Both"
                                     IsHitTestVisible="False">
                                <Canvas x:Name="RealtimePreviewCanvas"
                                        Width="1080"
                                        Height="1920"
                                        Background="Black"
                                        ClipToBounds="True" />
                            </Viewbox>
                            <Grid x:Name="PreviewGuidesOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                                <Border Margin="40" BorderBrush="#66FFFFFF" BorderThickness="1" />
                                <Border Margin="20" BorderBrush="#33FFFFFF" BorderThickness="1" />
                                <Border Width="1" Background="#44FFFFFF" HorizontalAlignment="Center" />
                                <Border Height="1" Background="#44FFFFFF" VerticalAlignment="Center" />
                            </Grid>
                            <Canvas x:Name="PreviewInteractionCanvas"
                                    Visibility="Collapsed"
                                    Background="Transparent"
                                    ClipToBounds="True" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="66" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PreviewTimeText" Text="00:00" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource AccentHoverBrush}" FontSize="10.5" VerticalAlignment="Center" />
                        <Slider x:Name="PreviewSeekSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="1"
                                Value="0"
                                SmallChange="0.1"
                                LargeChange="1"
                                IsMoveToPointEnabled="True"
                                Margin="8,0"
                                ToolTip="Click or drag to seek"
                                AutomationProperties.Name="Source preview position" />
                        <TextBlock x:Name="PreviewDurationText" Grid.Column="2" Text="00:00" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="3" Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PreviewTimeBox" Width="82" Height="24" Text="00:00" FontFamily="Cascadia Mono, Consolas" FontSize="10.5" VerticalContentAlignment="Center" ToolTip="Enter source timecode" Visibility="Collapsed" />
                        <TextBlock x:Name="PreviewMarkInText" Grid.Column="1" Text="In --:--" Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0" />
                        <TextBlock x:Name="PreviewMarkOutText" Grid.Column="2" Text="Out --:--" Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Border Grid.Row="4"
                            MinHeight="76"
                            Background="{StaticResource EditorRailBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid Margin="10,6">
                            <ScrollViewer x:Name="PreviewTransportScrollViewer"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          PanningMode="HorizontalOnly"
                                          PreviewMouseWheel="PreviewTransportScrollViewer_PreviewMouseWheel">
                                <StackPanel x:Name="PreviewTransportPanel"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button x:Name="PreviewMarkInButton" Style="{StaticResource IconButtonStyle}" ToolTip="Mark In (I)" AutomationProperties.Name="Set source mark in">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,3 L5,15 M8,5 L14,5 M8,13 L14,13" />
                                    </Button>
                                    <Button x:Name="PreviewMarkOutButton" Style="{StaticResource IconButtonStyle}" ToolTip="Mark Out (O)" AutomationProperties.Name="Set source mark out">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M13,3 L13,15 M4,5 L10,5 M4,13 L10,13" />
                                    </Button>
                                    <Button x:Name="PreviewClearMarksButton" Style="{StaticResource IconButtonStyle}" ToolTip="Clear In/Out" AutomationProperties.Name="Clear source marks">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,4 L14,14 M14,4 L4,14 M2,2 L16,2" />
                                    </Button>
                                    <ToggleButton x:Name="PreviewLoopToggle" Style="{StaticResource ToolToggleButtonStyle}" ToolTip="Loop marked range" AutomationProperties.Name="Loop marked range">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,7 C5,3 13,3 15,7 M15,7 L12,5 M15,7 L13,10 M14,11 C12,15 4,15 3,11 M3,11 L6,13 M3,11 L5,8" />
                                    </ToggleButton>
                                    <Button x:Name="PreviewSpeedButton" Style="{StaticResource IconButtonStyle}" Margin="4,0" ToolTip="Playback speed: 1x. Click to cycle." AutomationProperties.Name="Cycle playback speed">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,12 A6,6 0 1 1 15,12 M9,9 L13,6 M9,9 L9,4" />
                                    </Button>
                                    <Button x:Name="PreviewInsertButton" Style="{StaticResource IconButtonStyle}" Margin="4,0,0,0" ToolTip="Insert marked range at playhead" AutomationProperties.Name="Insert marked range">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,4 L3,14 M7,5 L13,9 L7,13 Z M15,4 L15,14" />
                                    </Button>
                                    <Button x:Name="PreviewOverwriteButton" Style="{StaticResource IconButtonStyle}" Margin="4,0,0,0" ToolTip="Overwrite marked range at playhead" AutomationProperties.Name="Overwrite marked range">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,4 L15,4 L15,14 L3,14 Z M6,7 L12,7 L12,11 L6,11 Z" />
                                    </Button>
                                    <ToggleButton x:Name="PreviewMuteToggle" Style="{StaticResource ToolToggleButtonStyle}" Margin="12,0,0,0" ToolTip="Mute source preview" AutomationProperties.Name="Mute source preview">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,7 L7,7 L11,4 L11,14 L7,11 L3,11 Z M13,7 L17,11 M17,7 L13,11" />
                                    </ToggleButton>
                                    <Slider x:Name="PreviewVolumeSlider" Width="72" Minimum="0" Maximum="1" Value="1" Margin="4,0" ToolTip="Preview volume" />
                                    <Button x:Name="PreviewZoomButton" Style="{StaticResource IconButtonStyle}" ToolTip="Monitor zoom: Fit. Click to cycle." AutomationProperties.Name="Cycle monitor zoom">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,8 A5,5 0 1 0 13,8 A5,5 0 1 0 3,8 M11.5,11.5 L16,16 M6,8 L10,8 M8,6 L8,10" />
                                    </Button>
                                    <ToggleButton x:Name="PreviewGuidesToggle" Style="{StaticResource ToolToggleButtonStyle}" Margin="4,0,0,0" ToolTip="Show canvas guides" AutomationProperties.Name="Show canvas guides">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M6,2 L6,16 M12,2 L12,16 M2,6 L16,6 M2,12 L16,12" />
                                    </ToggleButton>
                                    <Button x:Name="PreviewCanvasSettingsButton" Style="{StaticResource IconButtonStyle}" Margin="4,0,0,0" ToolTip="Canvas, frame rate, background, and layout guides" AutomationProperties.Name="Canvas settings">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,4 L15,4 M6,4 L6,8 M3,9 L15,9 M12,9 L12,13 M3,14 L15,14 M8,14 L8,10" />
                                    </Button>
                                    <Button x:Name="PreviewSnapshotButton" Style="{StaticResource IconButtonStyle}" ToolTip="Save current frame" AutomationProperties.Name="Save preview snapshot">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,6 L6,6 L8,4 L12,4 L14,6 L16,6 L16,14 L3,14 Z M7,10 A3,3 0 1 0 13,10 A3,3 0 1 0 7,10" />
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right inspector dock -->
            <GridSplitter x:Name="InspectorSplitter"
                          Grid.Column="3"
                          Grid.Row="0"
                          Grid.RowSpan="3"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Grid x:Name="RightPanelHost" Grid.Column="4" Grid.Row="0" Grid.RowSpan="3" AutomationProperties.Name="Inspector window">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition x:Name="RightInspectorRow" Height="*" />
                    <RowDefinition x:Name="RightTasksRow" Height="0" />
                </Grid.RowDefinitions>

                <Border x:Name="InspectorWindowTitleBar"
                        Grid.Row="0"
                        Background="{StaticResource EditorRailBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1,0,0,1">
                    <Grid Margin="6,0,12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="InspectorWindowDragHandle"
                                Grid.Column="0"
                                Width="28"
                                Height="28"
                                Cursor="SizeAll"
                                Background="Transparent"
                                ToolTip="Drag to move Inspector"
                                AutomationProperties.Name="Move Inspector window">
                            <TextBlock Text="⠿" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <TextBlock x:Name="InspectorWindowTitleText"
                                   Grid.Column="1"
                                   Text="Inspector"
                                   FontSize="11.5"
                                   FontWeight="SemiBold"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                    </Grid>
                </Border>

                <Border x:Name="InspectorBorder"
                        Grid.Row="1"
                        AutomationProperties.Name="Inspector window"
                        Background="{StaticResource EditorPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition x:Name="InspectorFooterRow" Height="52" />
                        </Grid.RowDefinitions>
                    <TabControl x:Name="InspectorTabs" Grid.Row="0" Background="Transparent" ClipToBounds="True">
                        <TabControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </TabControl.ItemsPanel>
                        <TabItem x:Name="PropertiesInspectorTab" Header="Properties">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Margin="14,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="11" Height="11" BorderBrush="{StaticResource TextMutedBrush}" BorderThickness="1" CornerRadius="2" Margin="0,0,7,0" />
                                        <TextBlock x:Name="InspectorTitle" Text="No clip selected" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="250" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid x:Name="InspectorPanel">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel>
                                                <Border x:Name="TransitionInspectorCard" Style="{StaticResource InspectorSectionStyle}" Visibility="Collapsed">
                                                    <StackPanel>
                                                        <TextBlock Text="Transition" Style="{StaticResource InspectorHeadingStyle}" />
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                            <TextBlock Text="Type" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <ComboBox x:Name="TransitionKindCombo" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,7" AutomationProperties.Name="Transition type" />
                                                            <TextBlock Text="Duration" Grid.Row="1" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <TextBox x:Name="TransitionDurationBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,6,7" AutomationProperties.Name="Transition duration" />
                                                            <TextBlock Text="s" Grid.Row="1" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,0,7" />
                                                            <TextBlock Text="Alignment" Grid.Row="2" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <TextBox x:Name="TransitionAlignmentBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="2" Grid.Column="1" Margin="0,0,6,0" AutomationProperties.Name="Transition alignment" />
                                                            <TextBlock Text="%" Grid.Row="2" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                            <TextBlock Text="Audio" Grid.Row="3" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,7,0,0" />
                                                            <ComboBox x:Name="TransitionAudioModeCombo" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,7,0,0" AutomationProperties.Name="Transition audio behavior" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <Expander x:Name="TransformInspectorExpander" Header="Transform" Style="{StaticResource InspectorExpanderStyle}" IsExpanded="True">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Field layout" Style="{StaticResource InspectorFieldLabelStyle}" VerticalAlignment="Center" />
                                                            <ComboBox x:Name="InspectorFieldColumnsCombo" Grid.Column="1" Width="104" SelectedIndex="1" AutomationProperties.Name="Inspector field columns">
                                                                <ComboBoxItem Content="1 column" Tag="1" />
                                                                <ComboBoxItem Content="2 columns" Tag="2" />
                                                                <ComboBoxItem Content="3 columns" Tag="3" />
                                                            </ComboBox>
                                                        </Grid>
                                                        <UniformGrid x:Name="TransformFieldsGrid" Columns="2" Margin="0,9,0,0">
                                                            <StackPanel Margin="0,0,6,8">
                                                                <TextBlock Text="Position X" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,4" />
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                                    <TextBox x:Name="PositionXBox" Style="{StaticResource InspectorNumericTextBoxStyle}" ToolTip="Horizontal position" AutomationProperties.Name="Horizontal position" />
                                                                    <TextBlock Grid.Column="1" Text="px" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="5,0,0,0" />
                                                                </Grid>
                                                            </StackPanel>
                                                            <StackPanel Margin="6,0,0,8">
                                                                <TextBlock Text="Position Y" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,4" />
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                                    <TextBox x:Name="PositionYBox" Style="{StaticResource InspectorNumericTextBoxStyle}" ToolTip="Vertical position" AutomationProperties.Name="Vertical position" />
                                                                    <TextBlock Grid.Column="1" Text="px" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="5,0,0,0" />
                                                                </Grid>
                                                            </StackPanel>
                                                            <StackPanel Margin="0,0,6,8">
                                                                <TextBlock Text="Scale X" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,4" />
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                                    <TextBox x:Name="ScaleXBox" Style="{StaticResource InspectorNumericTextBoxStyle}" AutomationProperties.Name="Horizontal scale" />
                                                                    <TextBlock Grid.Column="1" Text="×" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="5,0,0,0" />
                                                                </Grid>
                                                            </StackPanel>
                                                            <StackPanel Margin="6,0,0,8">
                                                                <TextBlock Text="Scale Y" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,4" />
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                                    <TextBox x:Name="ScaleYBox" Style="{StaticResource InspectorNumericTextBoxStyle}" AutomationProperties.Name="Vertical scale" />
                                                                    <TextBlock Grid.Column="1" Text="×" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="5,0,0,0" />
                                                                </Grid>
                                                            </StackPanel>
                                                            <StackPanel Margin="6,0,0,8">
                                                                <TextBlock Text="Rotation" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,4" />
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                                    <TextBox x:Name="RotationBox" Style="{StaticResource InspectorNumericTextBoxStyle}" AutomationProperties.Name="Rotation" />
                                                                    <TextBlock Grid.Column="1" Text="°" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="5,0,0,0" />
                                                                </Grid>
                                                            </StackPanel>
                                                            <StackPanel Margin="0,0,6,0">
                                                                <TextBlock Text="Opacity" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,4" />
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                                    <TextBox x:Name="OpacityBox" Style="{StaticResource InspectorNumericTextBoxStyle}" AutomationProperties.Name="Opacity" />
                                                                    <TextBlock Grid.Column="1" Text="%" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="5,0,0,0" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </UniformGrid>
                                                        <Button x:Name="OpenAnimationEditorButton"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Margin="0,10,0,0"
                                                                HorizontalAlignment="Stretch"
                                                                ToolTip="Open animation graph"
                                                                AutomationProperties.Name="Open animation graph"
                                                                IsEnabled="False">
                                                            <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,13 C6,13 6,5 9,5 C12,5 12,11 15,11 M3,15 L15,15" />
                                                        </Button>
                                                    </StackPanel>
                                                </Expander>

                                                <Expander x:Name="TextInspectorExpander" Header="Text &amp; Typography" Style="{StaticResource InspectorExpanderStyle}" IsExpanded="True" Visibility="Collapsed">
                                                    <StackPanel>
                                                        <TextBlock Text="Content" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,5" />
                                                        <TextBox x:Name="TextContentBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="70" VerticalScrollBarVisibility="Auto" AutomationProperties.Name="Text content" />
                                                        <TextBlock Text="Font family" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,10,0,5" />
                                                        <ComboBox x:Name="FontFamilyCombo" IsEditable="True" IsTextSearchEnabled="True" MinHeight="30" AutomationProperties.Name="Font family" />
                                                        <Grid Margin="0,10,0,0">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="Font size" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,5" />
                                                                <TextBox x:Name="FontSizeBox" Style="{StaticResource InspectorNumericTextBoxStyle}" AutomationProperties.Name="Font size" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Alignment" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,5" />
                                                                <ComboBox x:Name="FontAlignCombo" MinHeight="30" AutomationProperties.Name="Text alignment">
                                                                    <ComboBoxItem Content="Left" Tag="left" />
                                                                    <ComboBoxItem Content="Center" Tag="center" />
                                                                    <ComboBoxItem Content="Right" Tag="right" />
                                                                </ComboBox>
                                                            </StackPanel>
                                                        </Grid>
                                                        <CheckBox x:Name="FontBoldToggle" Content="Bold" Margin="0,9,0,0" AutomationProperties.Name="Bold text" />
                                                        <Grid Margin="0,10,0,0">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="Fill color" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,5" />
                                                                <TextBox x:Name="TextFillColorBox" Text="#FFFFFF" AutomationProperties.Name="Text fill color" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Outline color" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,5" />
                                                                <TextBox x:Name="TextOutlineColorBox" Text="#000000" AutomationProperties.Name="Text outline color" />
                                                            </StackPanel>
                                                        </Grid>
                                                        <Grid Margin="0,10,0,0">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="Outline width" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,5" />
                                                                <TextBox x:Name="TextOutlineWidthBox" Style="{StaticResource InspectorNumericTextBoxStyle}" AutomationProperties.Name="Text outline width" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Shadow opacity %" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,0,0,5" />
                                                                <TextBox x:Name="TextShadowOpacityBox" Style="{StaticResource InspectorNumericTextBoxStyle}" AutomationProperties.Name="Text shadow opacity" />
                                                            </StackPanel>
                                                        </Grid>
                                                        <TextBlock Text="Shadow color" Style="{StaticResource InspectorFieldLabelStyle}" Margin="0,10,0,5" />
                                                        <TextBox x:Name="TextShadowColorBox" Text="#000000" AutomationProperties.Name="Text shadow color" />
                                                    </StackPanel>
                                                </Expander>

                                                <Expander x:Name="TimingInspectorExpander" Header="Timing" Style="{StaticResource InspectorExpanderStyle}" IsExpanded="True">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Speed" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <TextBox x:Name="SpeedBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Column="1" Margin="0,0,6,0" AutomationProperties.Name="Playback speed" />
                                                            <TextBlock Text="x" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                        </Grid>
                                                        <CheckBox x:Name="ReverseToggle" Content="Reverse playback" Margin="78,9,0,0" AutomationProperties.Name="Reverse playback" />
                                                    </StackPanel>
                                                </Expander>

                                                <Expander x:Name="FadesInspectorExpander" Header="Transitions &amp; audio fades" Style="{StaticResource InspectorExpanderStyle}" IsExpanded="True" Visibility="Collapsed">
                                                    <StackPanel>
                                                        <TextBlock Text="Visual entrance and exit" Style="{StaticResource InspectorHeadingStyle}" />
                                                        <Grid Margin="0,6,0,0">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /><ColumnDefinition Width="62" /></Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                            <TextBlock Text="Entrance" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <ComboBox x:Name="VisualTransitionInCombo" Grid.Column="1" Margin="0,0,6,8" AutomationProperties.Name="Visual entrance transition" />
                                                            <TextBox x:Name="VisualTransitionInDurationBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Column="2" Margin="0,0,0,8" AutomationProperties.Name="Visual entrance duration" />
                                                            <TextBlock Text="Exit" Grid.Row="1" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <ComboBox x:Name="VisualTransitionOutCombo" Grid.Row="1" Grid.Column="1" Margin="0,0,6,0" AutomationProperties.Name="Visual exit transition" />
                                                            <TextBox x:Name="VisualTransitionOutDurationBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="1" Grid.Column="2" AutomationProperties.Name="Visual exit duration" />
                                                        </Grid>
                                                        <TextBlock Text="These animate only the selected item. Other clips, captions, overlays, and tracks remain unchanged." Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" Margin="78,7,0,12" />
                                                        <TextBlock Text="Audio fades" Style="{StaticResource InspectorHeadingStyle}" />
                                                        <Grid Margin="0,6,0,0">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                            <TextBlock Text="Fade in" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <TextBox x:Name="FadeInBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Column="1" Margin="0,0,6,8" AutomationProperties.Name="Audio fade in duration" />
                                                            <TextBlock Text="s" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,0,8" />
                                                            <TextBlock Text="Fade out" Grid.Row="1" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <TextBox x:Name="FadeOutBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,6,0" AutomationProperties.Name="Audio fade out duration" />
                                                            <TextBlock Text="s" Grid.Row="1" Grid.Column="2" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Expander>

                                                <Expander x:Name="ColorInspectorExpander" Header="Color" Style="{StaticResource InspectorExpanderStyle}" IsExpanded="True">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /><ColumnDefinition Width="58" /></Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                            <TextBlock Text="Brightness" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <Slider x:Name="BrightnessSlider" Grid.Column="1" Minimum="-1" Maximum="1" Value="0" Margin="0,0,7,7" AutomationProperties.Name="Brightness" />
                                                            <TextBox x:Name="BrightnessBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Column="2" Margin="0,0,0,7" AutomationProperties.Name="Brightness value" />
                                                            <TextBlock Text="Contrast" Grid.Row="1" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <Slider x:Name="ContrastSlider" Grid.Row="1" Grid.Column="1" Minimum="-1" Maximum="3" Value="0" Margin="0,0,7,7" AutomationProperties.Name="Contrast" />
                                                            <TextBox x:Name="ContrastBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="1" Grid.Column="2" Margin="0,0,0,7" AutomationProperties.Name="Contrast value" />
                                                            <TextBlock Text="Saturation" Grid.Row="2" Style="{StaticResource InspectorFieldLabelStyle}" />
                                                            <Slider x:Name="SaturationSlider" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="4" Value="1" Margin="0,0,7,0" AutomationProperties.Name="Saturation" />
                                                            <TextBox x:Name="SaturationBox" Style="{StaticResource InspectorNumericTextBoxStyle}" Grid.Row="2" Grid.Column="2" AutomationProperties.Name="Saturation value" />
                                                        </Grid>
                                                        <CheckBox x:Name="BlackWhiteToggle" Content="Black and white" Margin="78,9,0,0" AutomationProperties.Name="Black and white" />
                                                    </StackPanel>
                                                </Expander>

                                                <Expander x:Name="StabilizationInspectorExpander" Header="Stabilization" Style="{StaticResource InspectorExpanderStyle}" IsExpanded="False">
                                                    <StackPanel>
                                                        <CheckBox x:Name="StabilizeToggle" Content="Enable stabilization" AutomationProperties.Name="Enable stabilization" />
                                                        <Button x:Name="AnalyzeStabilizationButton" Style="{StaticResource IconButtonStyle}" Margin="0,9,0,0" HorizontalAlignment="Stretch" ToolTip="Analyze motion for stabilization" AutomationProperties.Name="Analyze stabilization motion">
                                                            <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,12 L6,8 L9,11 L12,5 L15,9 M3,15 L15,15" />
                                                        </Button>
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>

                                    <StackPanel x:Name="InspectorEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="28" IsHitTestVisible="False">
                                        <Border Width="44" Height="44" CornerRadius="10" Background="{StaticResource AccentSurfaceBrush}" HorizontalAlignment="Center">
                                            <Path Data="M4,4 L16,4 L16,16 L4,16 Z M7,8 L13,8 M7,11 L12,11" Stroke="{StaticResource AccentHoverBrush}" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Margin="10" />
                                        </Border>
                                        <TextBlock Text="Select a timeline clip" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,11,0,0" />
