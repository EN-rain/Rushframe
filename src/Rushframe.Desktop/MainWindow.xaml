                                </Grid.RowDefinitions>
                                <WrapPanel Margin="0,0,0,6">
                                    <Button x:Name="AddPortraitVariantButton" Style="{StaticResource IconButtonStyle}" Margin="0,0,5,5" ToolTip="Add a 9:16 vertical social variant" AutomationProperties.Name="Add portrait variant">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,2 L13,2 L13,16 L5,16 Z M15,10 L15,16 M12,13 L18,13" />
                                    </Button>
                                    <Button x:Name="AddLandscapeVariantButton" Style="{StaticResource IconButtonStyle}" Margin="0,0,5,5" ToolTip="Add a 16:9 landscape variant" AutomationProperties.Name="Add landscape variant">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M2,5 L14,5 L14,13 L2,13 Z M16,10 L16,16 M13,13 L19,13" />
                                    </Button>
                                    <Button x:Name="AddSquareVariantButton" Style="{StaticResource IconButtonStyle}" Margin="0,0,5,5" ToolTip="Add a 1:1 square variant" AutomationProperties.Name="Add square variant">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,3 L13,3 L13,13 L3,13 Z M16,10 L16,16 M13,13 L19,13" />
                                    </Button>
                                    <Button x:Name="RenderVariantButton" Style="{StaticResource PrimaryIconButtonStyle}" Margin="0,0,5,5" ToolTip="Render selected output variant" AutomationProperties.Name="Render selected variant">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Stroke="White" Margin="0" Data="M5,3 L15,9 L5,15 Z" />
                                    </Button>
                                    <Button x:Name="RefreshVariantsButton" Style="{StaticResource IconButtonStyle}" Margin="0,0,0,5" ToolTip="Refresh output variants" AutomationProperties.Name="Refresh variants">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,7 C5,3 13,3 15,7 M15,7 L12,5 M15,7 L13,10 M14,11 C12,15 4,15 3,11 M3,11 L6,13 M3,11 L5,8" />
                                    </Button>
                                </WrapPanel>
                                <ListBox x:Name="OutputVariantList" Grid.Row="1" AutomationProperties.Name="Output variants" />
                                <Grid Grid.Row="2" Margin="0,7,0,5">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Render receipts" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <Button x:Name="OpenRenderReceiptButton" Grid.Column="1" Style="{StaticResource IconButtonStyle}" ToolTip="Open selected render receipt" AutomationProperties.Name="Open render receipt">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,2 L13,2 L16,5 L16,16 L4,16 Z M13,2 L13,6 L16,6 M7,9 L13,9 M7,12 L13,12" />
                                    </Button>
                                </Grid>
                                <ListBox x:Name="RenderReceiptList" Grid.Row="3" AutomationProperties.Name="Render verification receipts" />
                            </Grid>
                        </TabItem>
                        <TabItem x:Name="GeneratedCompositionsTab" Header="Compositions" Visibility="Collapsed">
                            <DockPanel Margin="8">
                                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,7">
                                    <Button x:Name="RegisterRemotionButton" Style="{StaticResource IconButtonStyle}" Margin="0,0,5,5" ToolTip="Register a local Remotion composition" AutomationProperties.Name="Add Remotion composition">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,4 L12,4 L12,13 L3,13 Z M15,5 L15,15 M12,10 L18,10" />
                                    </Button>
                                    <Button x:Name="RegisterHyperFramesButton" Style="{StaticResource IconButtonStyle}" Margin="0,0,5,5" ToolTip="Register a local HyperFrames composition" AutomationProperties.Name="Add HyperFrames composition">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,5 L7,5 L7,13 L3,13 Z M10,5 L14,5 L14,13 L10,13 Z M17,6 L17,14 M14,10 L20,10" />
                                    </Button>
                                    <Button x:Name="RenderCompositionButton" Style="{StaticResource PrimaryIconButtonStyle}" Margin="0,0,5,5" ToolTip="Render selected composition" AutomationProperties.Name="Render selected composition">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Stroke="White" Margin="0" Data="M5,3 L15,9 L5,15 Z" />
                                    </Button>
                                    <Button x:Name="OpenCompositionOutputButton" Style="{StaticResource IconButtonStyle}" Margin="0,0,0,5" ToolTip="Open selected composition output" AutomationProperties.Name="Open composition output">
                                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,4 L10,4 M10,4 L10,10 M10,4 L15,9 M3,8 L3,15 L10,15" />
                                    </Button>
                                </WrapPanel>
                                <Grid>
                                    <ListBox x:Name="GeneratedCompositionList" AutomationProperties.Name="Generated composition adapters" />
                                    <TextBlock x:Name="GeneratedCompositionEmptyText" Text="Register a local Remotion or HyperFrames project. Rushframe renders it as a verified local asset." Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="250" IsHitTestVisible="False" />
                                </Grid>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>

            <Grid x:Name="UtilityWindowHost"
                  Grid.Column="0"
                  Grid.Row="0"
                  Visibility="Collapsed"
                  AutomationProperties.Name="Utility window">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border x:Name="UtilityWindowTitleBar"
                        Grid.Row="0"
                        Background="{StaticResource EditorRailBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1,0,1,1">
                    <Grid Margin="6,0,12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="UtilityWindowDragHandle"
                                Grid.Column="0"
                                Width="28"
                                Height="28"
                                Cursor="SizeAll"
                                Background="Transparent"
                                ToolTip="Drag to move the utility window"
                                AutomationProperties.Name="Move utility window">
                            <TextBlock Text="⠿" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <TextBlock x:Name="UtilityWindowTitleText"
                                   Grid.Column="1"
                                   Text="Utilities"
                                   FontSize="11.5"
                                   FontWeight="SemiBold"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                        <Button x:Name="UtilityCloseWindowButton"
                                Grid.Column="2"
                                Style="{StaticResource IconButtonStyle}"
                                Width="28"
                                Height="28"
                                Visibility="Collapsed"
                                ToolTip="Close utility window and its open tabs"
                                AutomationProperties.Name="Close utility window">
                            <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,5 L13,13 M13,5 L5,13" />
                        </Button>
                    </Grid>
                </Border>
                <ContentControl x:Name="UtilityWindowContentHost" Grid.Row="1" />
            </Grid>

            <!-- Timeline window -->
            <Grid x:Name="TimelineWindow"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  Grid.Row="2"
                  Grid.RowSpan="1"
                  AutomationProperties.Name="Timeline window">
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border x:Name="TimelineWindowTitleBar"
                        Grid.Row="0"
                        Background="{StaticResource EditorRailBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,1,1">
                    <Grid x:Name="TimelineToolbarBorder" Margin="5,0,7,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="TimelineWindowDragHandle"
                                Grid.Column="0"
                                Width="28"
                                Height="28"
                                Cursor="SizeAll"
                                Background="Transparent"
                                ToolTip="Drag to move Timeline"
                                AutomationProperties.Name="Move Timeline window">
                            <TextBlock Text="⠿" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <TextBlock x:Name="TimelineWindowTitleText"
                                   Grid.Column="1"
                                   Text="Timeline"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="6,0,10,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                        <ScrollViewer Grid.Column="2" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.SplitClip" ToolTip="Split the selected clip at the playhead" AutomationProperties.Name="Split clip">
                                    <Path Style="{StaticResource ToolbarIconStyle}" Data="M4,4 A2,2 0 1 0 8,4 A2,2 0 1 0 4,4 M4,14 A2,2 0 1 0 8,14 A2,2 0 1 0 4,14 M7.5,5.5 L15,13 M7.5,12.5 L15,5" />
                                </Button>
                                <ToggleButton x:Name="RippleToggle" Style="{StaticResource ToolToggleButtonStyle}" IsChecked="False" ToolTip="Close gaps after supported edits" Margin="6,0,4,0" AutomationProperties.Name="Ripple editing">
                                    <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M3,5 L7,9 L3,13 M15,5 L11,9 L15,13 M7,9 L11,9" />
                                </ToggleButton>
                                <ToggleButton x:Name="SnapToggle" Style="{StaticResource ToolToggleButtonStyle}" IsChecked="True" ToolTip="Snap clips and markers" Margin="0,0,8,0" AutomationProperties.Name="Timeline snapping">
                                    <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,3 L4,10 C4,15 14,15 14,10 L14,3 M4,7 L8,7 M10,7 L14,7" />
                                </ToggleButton>
                                <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.AddText" ToolTip="Add a text clip" AutomationProperties.Name="Add text">
                                    <Path Style="{StaticResource ToolbarIconStyle}" Data="M3,3 L15,3 M9,3 L9,15 M6,15 L12,15" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.Duplicate" ToolTip="Duplicate selected clip" AutomationProperties.Name="Duplicate selected clip">
                                    <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,5 L15,5 L15,15 L5,15 Z M2,2 L12,2 L12,5 M2,2 L2,12 L5,12" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.DeleteClip" ToolTip="Delete selected clip" AutomationProperties.Name="Delete selected clip">
                                    <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,5 L14,5 M7,5 L7,3 L11,3 L11,5 M6,7 L6,15 L12,15 L12,7" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.AddMarker" ToolTip="Add marker at the playhead" AutomationProperties.Name="Add timeline marker">
                                    <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,2 L5,16 M5,3 L13,3 L11,7 L13,11 L5,11 M15,12 L15,17 M12.5,14.5 L17.5,14.5" />
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                        <StackPanel x:Name="TimelineZoomControls" Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Background="{StaticResource EditorRailBrush}" Margin="8,0,0,0">
                            <Path Data="M2,9 A7,7 0 1 0 16,9 A7,7 0 1 0 2,9 M7,9 L11,9" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.3" Width="15" Height="15" Stretch="Uniform" Margin="0,0,8,0" />
                            <Slider x:Name="ZoomSlider" Width="118" Minimum="0.1" Maximum="10" Value="1" TickFrequency="0.1" AutomationProperties.Name="Timeline zoom" />
                            <Path Data="M2,9 A7,7 0 1 0 16,9 A7,7 0 1 0 2,9 M6,9 L12,9 M9,6 L9,12" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.3" Width="15" Height="15" Stretch="Uniform" Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border x:Name="TimelineBorder"
                        Grid.Row="1"
                        Background="{StaticResource ChromeBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <ContentControl x:Name="TimelineHost" />
                </Border>
            </Grid>

            <GridSplitter x:Name="PreviewTimelineSplitter"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Grid.Row="1"
                          Height="4"
                          VerticalAlignment="Top"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <GridSplitter x:Name="TimelineTasksSplitter" Visibility="Collapsed" />

            <Canvas x:Name="PanelDockOverlay"
                    Grid.Column="0"
                    Grid.ColumnSpan="5"
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    Panel.ZIndex="200"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <Border x:Name="PanelDockTargetHighlight"
                        Background="#338B5CF6"
                        BorderBrush="{StaticResource AccentHoverBrush}"
                        BorderThickness="2"
                        CornerRadius="6" />
                <Border x:Name="PanelDockDragBadge"
                        Padding="10,5"
                        Background="{StaticResource PanelRaisedBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="5">
                    <TextBlock x:Name="PanelDockDragLabel" FontSize="11" FontWeight="SemiBold" />
                </Border>
            </Canvas>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource EditorHeaderBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" FontSize="10.5" TextTrimming="CharacterEllipsis" />
                <ProgressBar x:Name="OperationProgressBar"
                             Grid.Column="1"
                             Width="132"
                             Height="8"
                             Margin="10,0,8,0"
                             IsIndeterminate="True"
                             Style="{StaticResource OperationProgressBarStyle}"
                             Visibility="Collapsed"
                             AutomationProperties.Name="Current operation progress" />
                <Button x:Name="CancelOperationButton"
                        Grid.Column="2"
                        Content="×"
                        Style="{StaticResource IconButtonStyle}"
                        MinHeight="26"
                        Margin="0,0,10,0"
                        ToolTip="Cancel current operation"
                        Visibility="Collapsed"
                        AutomationProperties.Name="Cancel current operation" />
                <TextBlock x:Name="LocalEditingStatusText" Grid.Column="3" Text="Rushframe — Local editing" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="10.5" />
                <TextBlock x:Name="AutosaveStatusText" Grid.Column="4" Text="Autosave enabled" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10.5" />
            </Grid>
        </Border>

        <Grid x:Name="GlobalFunctionSearchOverlay"
              Grid.RowSpan="3"
              Panel.ZIndex="100"
              Background="#B20A0710"
              Visibility="Collapsed">
            <Button x:Name="GlobalFunctionSearchBackdrop"
                    Background="Transparent"
                    BorderThickness="0"
                    Focusable="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />
            <Border Width="520"
                    MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                    MaxHeight="430"
                    Margin="20"
                    Padding="14"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Background="{StaticResource PanelRaisedBrush}"
                    BorderBrush="{StaticResource BorderStrongBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Margin="0,0,0,10"
                            MinHeight="42"
                            Background="{StaticResource InputBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="58" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0"
                                  Width="15"
                                  Height="15"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Stroke="{StaticResource TextMutedBrush}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  Data="M3,8 A5,5 0 1 0 13,8 A5,5 0 1 0 3,8 M11.5,11.5 L16,16"
                                  IsHitTestVisible="False" />
                            <TextBox x:Name="GlobalFunctionSearchBox"
                                     Grid.Column="1"
                                     Style="{x:Null}"
                                     MinHeight="40"
                                     Padding="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextBrush}"
                                     CaretBrush="{StaticResource TextBrush}"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Search commands and functions"
                                     AutomationProperties.Name="Search all functions" />
                            <TextBlock Grid.Column="2"
                                       Text="Ctrl+K"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="10.5"
                                       IsHitTestVisible="False" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="GlobalFunctionSearchHint"
                               Grid.Row="1"
                               Margin="2,0,0,8"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Type a command name"
                               FontSize="11" />
                    <Grid Grid.Row="2">
                        <ListBox x:Name="GlobalFunctionSearchResults"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="320"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="12,8" />
                                    <Setter Property="Margin" Value="0,0,0,4" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemChrome"
                                                        Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.45" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="12.5"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Category}"
                                                       Margin="0,2,0,0"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10.5" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Shortcut}"
                                                   Margin="14,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="10.5" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="GlobalFunctionSearchEmptyText"
                                   Text="No matching commands"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"
                                   IsHitTestVisible="False" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </Border>
</Window>
